# Gemini API Key (required)
GEMINI_API_KEY=your_gemini_api_key_here

# Server port
PORT=3001

# Cache TTL in seconds (default: 1 hour)
CACHE_TTL=3600

# Gemini model to use
GEMINI_MODEL=gemini-2.0-flash

# Max emails to fetch per classification request
MAX_EMAILS_PER_REQUEST=200

# Gemini batch size (emails per chunk sent to Gemini)
GEMINI_BATCH_SIZE=25
